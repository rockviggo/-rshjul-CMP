  <!-- MONTH OVERVIEW -->
  <div class="card p-5 mb-6">
    <h3 class="font-semibold text-gray-800 mb-4">Manedsoversikt - antall synlige utsendelser</h3>
    <div class="grid grid-cols-12 gap-1 text-center" id="monthGrid"></div>
  </div>

  <!-- TIMELINE -->
  <div class="card p-5">
    <h3 class="font-semibold text-gray-800 mb-4">Detaljert tidslinje per maned</h3>
    <div id="timelineDetail" class="space-y-4"></div>
  </div>

  <div class="text-center text-xs text-gray-400 py-6">Generert fra CMP - BI Arshjul 2026 - Mai 2026</div>
</div>

<script>
const tasks = [
