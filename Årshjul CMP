  {m:1, title:"SFMC - Invitasjon Apen Dag", type:"insp", pilar:"rekr", livs:"Prospekt", kanal:"SFMC", campus:"Oslo"},
  {m:1, title:"Sosiale Medier - Studentlife Reels", type:"insp", pilar:"rekr", livs:"Prospekt", kanal:"SoMe", campus:"Oslo"},
