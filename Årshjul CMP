      <div class="flex items-center justify-between pt-1 border-t border-gray-100">
        <p class="text-sm text-gray-500">Viser <span class="font-bold text-gray-800" id="visibleCount">48</span> av 48 oppgaver</p>
        <button class="text-xs text-indigo-600 font-semibold hover:text-indigo-800 cursor-pointer" onclick="resetFilters()">Nullstill filtre</button>
      </div>
    </div>
  </div>

  <!-- WHEEL -->
  <div class="card p-8 mb-6">
    <div class="wheel-container" id="wheel">
      <canvas id="wheelCanvas" width="780" height="780" style="position:absolute;top:0;left:0;"></canvas>
      <div id="dots"></div>
      <div id="tooltips"></div>
